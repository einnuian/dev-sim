ANTHROPIC_API_KEY=
GITHUB_TOKEN=
# Optional: default model for the coding agent (overridden by dev-sim -m)
ANTHROPIC_MODEL=
# Optional: default for a future review/second agent; falls back to ANTHROPIC_MODEL then default
ANTHROPIC_REVIEW_MODEL=

# PR review command (dev-sim-review): K2 Think (OpenAI-compatible) at https://api.k2think.ai/v1
K2_API_KEY=
# Optional: K2 model id (default: MBZUAI-IFM/K2-Think-v2)
K2_REVIEW_MODEL=

# Optional: directory containing trait_pools.json and generate_persona.py (DevTeam personas)
# DEV_SIM_PERSONAS_DIR=